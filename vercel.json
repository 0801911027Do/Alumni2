{
  "version": 2,
  "name": "alumni-tracking-system",
  "public": true,
  "builds": [
    {
      "src": "alumni.html",
      "use": "@vercel/static"
    },
    {
      "src": "alumni.css",
      "use": "@vercel/static"
    },
    {
      "src": "alumni.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/alumni.css",
      "dest": "/alumni.css",
      "headers": {
        "cache-control": "public, max-age=3600",
        "Content-Type": "text/css; charset=utf-8"
      }
    },
    {
      "src": "/alumni.js",
      "dest": "/alumni.js",
      "headers": {
        "cache-control": "public, max-age=3600",
        "Content-Type": "application/javascript; charset=utf-8"
      }
    },
    {
      "src": "/alumni.html",
      "dest": "/alumni.html",
      "headers": {
        "cache-control": "public, max-age=3600",
        "Content-Type": "text/html; charset=utf-8"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/alumni.html",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      }
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "buildCommand": "echo 'Static site'"
}
