{
  "version": 2,
  "name": "alumni-tracking-system",
  "public": true,
  "buildCommand": "npm run build || echo 'No build step needed'",
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/alumni.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
